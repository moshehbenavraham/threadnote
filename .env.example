# Vesper environment variables (all optional; the site renders without any set).
# Copy to `.env.local` and fill in the values relevant to your deployment.

# ---------------------------------------------------------------------------
# Site identity
# ---------------------------------------------------------------------------

# Canonical origin used by `scripts/generate-sitemap.mjs` AND `src/lib/site.ts`
# to emit consistent canonical / OG / JSON-LD URLs. Defaults to
# https://fashion-blog.app when unset.
VITE_SITE_URL=https://your-domain.tld

# Public-facing contact email (footer, About page, Organization JSON-LD).
# Defaults to hello@vesper.com.
VITE_CONTACT_EMAIL=hello@vesper.com

# Optional Twitter / X handle (e.g. "@vespermag"). When unset, the
# `twitter:site` meta tag is omitted entirely rather than emitting a
# fictional handle.
VITE_SITE_TWITTER=

# ---------------------------------------------------------------------------
# Social profiles
#
# Leave any variable blank to keep the corresponding link out of the footer
# and the Organization JSON-LD `sameAs` array. Templates that ship with
# `https://instagram.com` etc. point at the platform's homepage, not your
# profile, so we hide the column entirely until a real URL is set.
# ---------------------------------------------------------------------------

VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_TWITTER=
VITE_SOCIAL_PINTEREST=
VITE_SOCIAL_THREADS=
VITE_SOCIAL_MASTODON=

# ---------------------------------------------------------------------------
# Newsletter
# ---------------------------------------------------------------------------

# Newsletter signup endpoint (POST with JSON body { email, source }).
# When unset, NewsletterForm falls back to a prefilled mailto: draft.
VITE_NEWSLETTER_ENDPOINT=

# Recipient address for the mailto: fallback when VITE_NEWSLETTER_ENDPOINT
# is unset. Defaults to hello@vesper.com.
VITE_NEWSLETTER_EMAIL=hello@vesper.com
